generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  APPROVAL_MANAGER
  EVENT_STAFF
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  ATTENDED
  WITHDRAWN
}

enum ScanResult {
  SUCCESS
  INVALID
  ALREADY_USED
  WRONG_EVENT
}

enum AuditActorType {
  USER
  SYSTEM
  PUBLIC
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(APPROVAL_MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approvedRegistrations Registration[] @relation("ApprovedBy")
  scanLogs              ScanLog[]
  auditLogs             AuditLog[]
}

model Event {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  slug      String   @unique
  logoPath  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations           Registration[]
  emailTemplate           EmailTemplate?
  registrationFormConfig  RegistrationFormConfig?
}

model EmailTemplate {
  id        String   @id @default(cuid())
  eventId   String?  @unique
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subject   String
  htmlBody  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RegistrationFormConfig {
  id         String   @id @default(cuid())
  eventId    String?  @unique
  event      Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fieldsJson String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SystemSettings {
  id                         String   @id @default("global")
  platformName               String   @default("Court Events")
  supportEmail               String?
  supportPhone               String?
  qrInstructionsOverride     String?  @db.Text
  notifyEmailOnApprove       Boolean  @default(true)
  notifyWhatsAppOnApprove    Boolean  @default(true)
  notifySmsOnApprove         Boolean  @default(false)
  smsWhenWhatsAppUnavailable Boolean  @default(true)
  emailProviderPreference    String   @default("auto")
  maintenanceMode            Boolean  @default(false)
  maintenanceMessage         String?  @db.Text
  requireRegistrationNotes   Boolean  @default(false)
  allowPublicRegistration    Boolean  @default(true)
  updatedAt                  DateTime @updatedAt
}

model Registration {
  id           String             @id @default(cuid())
  eventId      String
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fullName     String
  rank         String
  entity       String
  email        String
  mobile       String
  notes        String?
  customData   Json               @default("{}")
  status       RegistrationStatus @default(PENDING)
  qrToken      String?            @unique
  qrSentAt     DateTime?
  qrUsedAt     DateTime?
  attendedAt   DateTime?
  approvedAt   DateTime?
  rejectedAt     DateTime?
  withdrawnAt    DateTime?
  withdrawalNote String?            @db.Text
  approvedById   String?
  approvedBy   User?              @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  scanLogs ScanLog[]

  @@unique([eventId, email])
  @@unique([eventId, mobile])
}

model ScanLog {
  id             String        @id @default(cuid())
  registrationId String?
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  eventId        String
  scannedById    String
  scannedBy      User          @relation(fields: [scannedById], references: [id])
  qrToken        String
  result         ScanResult
  judgeName      String?
  scannedAt      DateTime      @default(now())
  offlineId      String?       @unique
  syncedAt       DateTime?
}

model Locale {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  direction String   @default("rtl")
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries DictionaryEntry[]
}

model AuditLog {
  id          String         @id @default(cuid())
  action      String
  entityType  String?
  entityId    String?
  entityLabel String?
  actorType   AuditActorType @default(USER)
  actorUserId String?
  actorUser   User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorName   String?
  actorEmail  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?        @db.Text
  createdAt   DateTime       @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([action])
  @@index([entityType, entityId])
  @@index([actorUserId])
}

model DictionaryEntry {
  id        String   @id @default(cuid())
  localeId  String
  locale    Locale   @relation(fields: [localeId], references: [id], onDelete: Cascade)
  key       String
  namespace String   @default("common")
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([localeId, key])
  @@index([localeId, namespace])
}
